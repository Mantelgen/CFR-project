{
  "title": "web traffic & api monitoring",
  "uid": "web-api-monitoring",
  "schemaVersion": 36,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "request rate",
      "datasource": "Loki",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate({container=\"nginx-lb\"}[1m])",
          "refId": "A",
          "legendFormat": "requests/sec"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "api vs frontend traffic",
      "datasource": "Loki",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate({container=\"nginx-lb\"} |~ \"/api/\" [1m]))",
          "refId": "A",
          "legendFormat": "api"
        },
        {
          "expr": "sum(rate({container=\"nginx-lb\"} !~ \"/api/\" [1m]))",
          "refId": "B",
          "legendFormat": "frontend"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "status codes over time",
      "datasource": "Loki",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (status)(rate({container=\"nginx-lb\"} | pattern `<ip> - - <_> \"<method> <uri> <_>\" <status> <size> <_>` [1m]))",
          "refId": "A",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "piechart",
      "title": "http status distribution",
      "datasource": "Loki",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (status)(count_over_time({container=\"nginx-lb\"} | pattern `<ip> - - <_> \"<method> <uri> <_>\" <status> <size> <_>` [5m]))",
          "refId": "A",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "piechart",
      "title": "http methods",
      "datasource": "Loki",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "sum by (method)(count_over_time({container=\"nginx-lb\"} | pattern `<ip> - - <_> \"<method> <uri> <_>\" <status> <size> <_>` [5m]))",
          "refId": "A",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "type": "gauge",
      "title": "server errors (5xx last 5m)",
      "datasource": "Loki",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [
        {
          "expr": "sum(count_over_time({container=\"nginx-lb\"} | pattern `<ip> - - <_> \"<method> <uri> <_>\" <status> <size> <_>` | status =~ \"5..\" [5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "top api endpoints",
      "datasource": "Loki",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "topk(10, sum by (uri)(count_over_time({container=\"nginx-lb\"} | pattern `<ip> - - <_> \"<method> <uri> <_>\" <status> <size> <_>` | uri =~ \"/api/.*\" [5m])))",
          "refId": "A",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "type": "table",
      "title": "top client ips",
      "datasource": "Loki",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "topk(10, sum by (ip)(count_over_time({container=\"nginx-lb\"} | pattern `<ip> - - <_> \"<method> <uri> <_>\" <status> <size> <_>` [5m])))",
          "refId": "A",
          "legendFormat": "{{ip}}"
        }
      ]
    },
    {
      "type": "logs",
      "title": "live access logs",
      "datasource": "Loki",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "{container=\"nginx-lb\"}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "logs",
      "title": "error requests (4xx / 5xx)",
      "datasource": "Loki",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 42 },
      "targets": [
        {
          "expr": "{container=\"nginx-lb\"} | pattern `<ip> - - <_> \"<method> <uri> <_>\" <status> <size> <_>` | status =~ \"4..|5..\"",
          "refId": "A"
        }
      ]
    }
  ]
}
