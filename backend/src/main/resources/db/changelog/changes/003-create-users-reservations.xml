<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
 xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
 xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
 http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Users table -->
    <changeSet id="005-create-users" author="cosmin">

        <createTable tableName="users">

            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="username" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="email" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="first_name" type="VARCHAR(100)"/>

            <column name="last_name" type="VARCHAR(100)"/>

            <column name="is_active" type="BOOLEAN" defaultValue="true">
                <constraints nullable="false"/>
            </column>

            <column name="is_confirmed" type="BOOLEAN" defaultValue="false">
                <constraints nullable="false"/>
            </column>

            <column name="confirmation_token" type="VARCHAR(255)"/>

        </createTable>

    </changeSet>

    <!-- Reservations table -->
    <changeSet id="006-create-reservations" author="cosmin">

        <createTable tableName="reservations">

            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_reservations_users" references="users(id)"/>
            </column>

            <column name="train_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_reservations_trains" references="trains(id)"/>
            </column>

            <column name="number_of_seats" type="INT">
                <constraints nullable="false"/>
            </column>

            <column name="reservation_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="status" type="VARCHAR(50)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>

            <column name="confirmation_token" type="VARCHAR(255)"/>

            <column name="is_confirmed" type="BOOLEAN" defaultValue="false">
                <constraints nullable="false"/>
            </column>

        </createTable>

    </changeSet>

</databaseChangeLog>
