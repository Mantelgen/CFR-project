<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <changeSet id="1" author="yourname">
        <createTable tableName="trains">

            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="train_number" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>

            <column name="departure_station_id" type="BIGINT"/>

            <column name="arrival_station_id" type="BIGINT"/>

            <column name="departure_time" type="TIME"/>

            <column name="arrival_time" type="TIME"/>

        </createTable>
    </changeSet>

</databaseChangeLog>